# =============================================================================
# KNG7 — first_cheap_03 (BTC 5m or 15m UP/DOWN)
# =============================================================================
# Live: set POLY_DRY_RUN=false and real keys. Keep BOT_STRATEGY_MODE=first_cheap_03.

POLY_PRIVATE_KEY=replace_me
POLY_FUNDER=replace_me
POLY_SIGNATURE_TYPE=1
POLY_DRY_RUN=true

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_STRATEGY_MODE=first_cheap_03

# --- Entry ---
# btc50_1c (DEFAULT): first ≤ BOT_CHEAP03_PRICE_MAX touch + |Binance BTC - anchor| < BOT_BTC_MAX_MOVE_USD, then $1 FAK.
# dual_limits: GTC bids UP+DOWN at BOT_CHEAP03_LIMIT_PX × BOT_CHEAP03_LIMIT_SHARES.
# market: legacy FAK on first ≤ BOT_CHEAP03_PRICE_MAX (default 3¢), no BTC gate.
BOT_CHEAP03_ENTRY=btc50_1c
BOT_CHEAP03_PRICE_MAX=0.01
BOT_BTC_MAX_MOVE_USD=50
BOT_CHEAP03_NOTIONAL_USDC=1

# Binance spot for BTC gate (symbol only; public ticker endpoint)
BOT_BTC_FEED_ENABLED=true
BOT_BTC_FEED_SYMBOL=BTCUSDT

# Dual mode only:
BOT_CHEAP03_LIMIT_PX=0.03
BOT_CHEAP03_LIMIT_SHARES=34

# --- Take-profit (GTC limit sell per whole-share inventory) ---
BOT_TP_LIMIT_PX=0.70
BOT_TP_POLL_SECONDS=15

# --- Runtime ---
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0
BOT_LOG_LEVEL=INFO

# 5 or 15 — Gamma slug btc-updown-{5|15}m-<epoch>. Same strategy: 1c entry, BTC move gate, 70c TP.
# One bot process trades ONE length only (this value). Logs show 15m slugs while this stays 15.
# To run 5m and 15m together: keep 15 here for `bot`, then `docker compose --profile five_m up -d`
# (adds service `bot_5m` which overrides BOT_WINDOW_MINUTES to 5 — same wallet; mind double exposure).
BOT_WINDOW_MINUTES=15
BOT_MARKET_SYMBOL=BTC

BOT_POLY_FAK_CONFIRM_ORDER=true
