# =============================================================================
# KNG7 — limit_pair_5m (BTC 5m scheduled dual limits)
# =============================================================================
# Live: set POLY_DRY_RUN=false and real keys. Keep BOT_STRATEGY_MODE=limit_pair_5m.

POLY_PRIVATE_KEY=replace_me
POLY_FUNDER=replace_me
POLY_SIGNATURE_TYPE=1
POLY_DRY_RUN=true

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_STRATEGY_MODE=limit_pair_5m
BOT_MARKET_SYMBOL=BTC
BOT_WINDOW_MINUTES=5

# First window starts at the next 5m UTC boundary after (now + lead minutes).
# Default: 12 windows = 1 hour (e.g. now 07:53 → place for 08:10–09:10 UTC).
BOT_LIMIT_PAIR_LEAD_MINUTES=15
BOT_LIMIT_PAIR_WINDOW_COUNT=12
BOT_LIMIT_PAIR_UP_PX=0.50
BOT_LIMIT_PAIR_DOWN_PX=0.49
BOT_LIMIT_PAIR_SHARES=5
BOT_LIMIT_PAIR_SEARCH_INTERVAL_SEC=300
BOT_LIMIT_PAIR_ORDER_SPACING_SEC=10
BOT_LIMIT_PAIR_STATE_PATH=exports/limit_pair_state.json
BOT_LIMIT_PAIR_PRICE_TOL=0.01

# --- Runtime ---
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0
BOT_LOG_LEVEL=INFO

BOT_POLY_FAK_CONFIRM_ORDER=true

# Polymarket CLOB market WebSocket (optional; limit placement uses REST).
BOT_POLY_WS_ENABLED=true
BOT_POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
BOT_POLY_WS_MAX_AGE_SEC=12.0
