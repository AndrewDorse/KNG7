# =============================================================================
# KNG7 — limit_pair_5m (multi-asset 5m scheduled dual limits)
# =============================================================================
# Live: set POLY_DRY_RUN=false and real keys. Keep BOT_STRATEGY_MODE=limit_pair_5m.

POLY_PRIVATE_KEY=replace_me
# Profile / Deposit address from polymarket.com (usually NOT your MetaMask EOA).
POLY_FUNDER=replace_me
# 1=email/Magic proxy | 2=browser wallet Safe | 3=deposit wallet (POLY_1271, new accounts)
POLY_SIGNATURE_TYPE=2
# If Magic/proxy wallet fails on CLOB v2 ("deposit wallet flow"), force legacy client:
# BOT_CLOB_USE_V1=true
POLY_DRY_RUN=true

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_STRATEGY_MODE=limit_pair_5m
BOT_MARKET_SYMBOL=BTC
BOT_WINDOW_MINUTES=5

# --- limit_pair_5m trading (change .env only — no rebuild) ---
# Pairs to trade (comma-separated 5m UP/DOWN markets on Polymarket).
BOT_LIMIT_PAIR_SYMBOLS=BTC,ETH
# Limit buy price for UP leg (0.01–0.99).
BOT_LIMIT_PAIR_UP_PX=0.50
# Limit buy price for DOWN leg (0.01–0.99).
BOT_LIMIT_PAIR_DOWN_PX=0.49
# Shares per leg (UP and DOWN each get this size).
BOT_LIMIT_PAIR_SHARES=10

# --- limit_pair_5m schedule / runtime ---
# Every SEARCH cycle: queue not-yet-started 5m windows in the next N minutes.
# Skip first 3 only on the first SEARCH after container/process start (not every 5 min).
NEXT_WINDOWS_SEARCH_MINUTES=60
BOT_LIMIT_PAIR_SKIP_FIRST_WINDOWS=3
BOT_LIMIT_PAIR_SEARCH_INTERVAL_SEC=300
# Legacy (ignored by limit_pair search; kept for compatibility):
# BOT_LIMIT_PAIR_LEAD_MINUTES=15
# BOT_LIMIT_PAIR_HOURS=2
BOT_LIMIT_PAIR_ORDER_SPACING_SEC=10
# T+15…T+60s: poll every 1s (~45 passes) — cancel + sell until flat. Exit @ 1¢ hits bids.
BOT_LIMIT_PAIR_WINDOW_CLEANUP_OFFSET_SEC=15
BOT_LIMIT_PAIR_WINDOW_CLEANUP_UNTIL_SEC=60
BOT_LIMIT_PAIR_CLEANUP_POLL_SEC=1
BOT_LIMIT_PAIR_EXIT_SELL_PX=0.01
BOT_LIMIT_PAIR_CLEANUP_SELL_MAX_ROUNDS=8
# Docker: use /app/data (named volume). Local run: exports/limit_pair_state.json
BOT_LIMIT_PAIR_STATE_PATH=/app/data/limit_pair_state.json
BOT_LIMIT_PAIR_PRICE_TOL=0.01

# --- Runtime ---
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0
BOT_LOG_LEVEL=INFO

BOT_POLY_FAK_CONFIRM_ORDER=true

# Polymarket CLOB market WebSocket (optional; limit placement uses REST).
BOT_POLY_WS_ENABLED=true
BOT_POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
BOT_POLY_WS_MAX_AGE_SEC=12.0
