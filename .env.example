# =============================================================================
# KNG7 — first_cheap_03 (BTC 15m UP/DOWN)
# =============================================================================
# Live: set POLY_DRY_RUN=false and real keys. Keep BOT_STRATEGY_MODE=first_cheap_03.

POLY_PRIVATE_KEY=replace_me
POLY_FUNDER=replace_me
POLY_SIGNATURE_TYPE=1
POLY_DRY_RUN=true

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_STRATEGY_MODE=first_cheap_03

# --- Entry (default: dual resting limits on BOTH sides) ---
# dual_limits = GTC BUY UP + DOWN at limit price each new window (no FAK first-touch).
# market = legacy: no entry limits; one $1 FAK when midpoint first touches ≤ BOT_CHEAP03_PRICE_MAX.
BOT_CHEAP03_ENTRY=dual_limits
BOT_CHEAP03_LIMIT_PX=0.03
BOT_CHEAP03_LIMIT_SHARES=34

# Legacy market mode only:
BOT_CHEAP03_PRICE_MAX=0.03
BOT_CHEAP03_NOTIONAL_USDC=1

# --- Take-profit (GTC sells at 99¢ for whole-share inventory per side) ---
BOT_TP_POLL_SECONDS=15

# --- Runtime ---
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0
BOT_LOG_LEVEL=INFO

BOT_WINDOW_MINUTES=15
BOT_MARKET_SYMBOL=BTC

BOT_POLY_FAK_CONFIRM_ORDER=true
