# =============================================================================
# KNG7 - late_high_5m (BTC 5m 99c GTC limit buy)
# =============================================================================
# Live: set real keys and POLY_DRY_RUN=false.

POLY_PRIVATE_KEY=replace_me
# Profile / Deposit address from polymarket.com (usually NOT your MetaMask EOA).
POLY_FUNDER=replace_me
# 1=email/Magic proxy | 2=browser wallet Safe | 3=deposit wallet
POLY_SIGNATURE_TYPE=2
# If deposit-wallet flow fails on CLOB v2, try legacy client:
# BOT_CLOB_USE_V1=true
POLY_DRY_RUN=true

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_STRATEGY_MODE=late_high_5m
BOT_MARKET_SYMBOL=BTC
BOT_WINDOW_MINUTES=5

# --- late_high_5m trading ---
# Watch late in the BTC 5m window. Early phase is stricter; fallback starts at 295s.
BOT_LATE_HIGH_ENTRY_LO_SEC=290
BOT_LATE_HIGH_ENTRY_HI_SEC=299
BOT_LATE_HIGH_FALLBACK_SEC=295
BOT_LATE_HIGH_MIN_LEG_PX=0.80
# Real GTC limit buy price.
BOT_LATE_HIGH_LIMIT_PX=0.99
# Sizing: max(50% available USDC / limit_px, min_shares). Skip if balance cannot cover min_shares.
BOT_LATE_HIGH_MIN_SHARES=5
BOT_LATE_HIGH_EARLY_BASE_GAP_USD=75
BOT_LATE_HIGH_LATE_BASE_GAP_USD=0
BOT_LATE_HIGH_RANGE_LOOKBACK_SEC=30
BOT_LATE_HIGH_RANGE_GAP_MULT=0.05
BOT_LATE_HIGH_VOLUME_SQRT_GAP_MULT=0.50
BOT_LATE_HIGH_MAX_RECENT_RANGE_USD=150
# 0 disables the 10s move cap; recent-range cap handles high-volatility skips by default.
BOT_LATE_HIGH_MAX_MOVE_10S_USD=0
BOT_LATE_HIGH_STATS_REFRESH_SECONDS=5
BOT_LATE_HIGH_STATE_PATH=/app/data/late_high_state.json

# --- Runtime ---
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0
BOT_LOG_LEVEL=INFO

# Polymarket CLOB market WebSocket (optional; quotes fall back to REST orderbook).
BOT_POLY_WS_ENABLED=true
BOT_POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
BOT_POLY_WS_MAX_AGE_SEC=12.0

# =============================================================================
# Legacy fallback: set BOT_STRATEGY_MODE=limit_pair_5m to use scheduled dual limits.
# =============================================================================
BOT_LIMIT_PAIR_SYMBOLS=BTC,ETH
BOT_LIMIT_PAIR_UP_PX=0.50
BOT_LIMIT_PAIR_DOWN_PX=0.49
BOT_LIMIT_PAIR_SHARES=10
NEXT_WINDOWS_SEARCH_MINUTES=60
BOT_LIMIT_PAIR_SKIP_FIRST_WINDOWS=3
BOT_LIMIT_PAIR_SEARCH_INTERVAL_SEC=300
BOT_LIMIT_PAIR_ORDER_SPACING_SEC=10
BOT_LIMIT_PAIR_WINDOW_CLEANUP_OFFSET_SEC=15
BOT_LIMIT_PAIR_WINDOW_CLEANUP_UNTIL_SEC=60
BOT_LIMIT_PAIR_CLEANUP_POLL_SEC=1
BOT_LIMIT_PAIR_EXIT_SELL_PX=0.01
BOT_LIMIT_PAIR_CLEANUP_SELL_MAX_ROUNDS=8
BOT_LIMIT_PAIR_STATE_PATH=/app/data/limit_pair_state.json
BOT_LIMIT_PAIR_PRICE_TOL=0.01
